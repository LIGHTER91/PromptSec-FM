# Examples only. PromptSec does not automatically load this file.
# Codex CLI generation uses the saved ChatGPT session and only needs an explicit model identifier:
# PROMPTSEC_CODEX_MODEL=<exact-codex-model-id>

# OpenAI-compatible HTTP generation:
PROMPTSEC_GENERATION_PROVIDER=openai_compatible
PROMPTSEC_GENERATION_MODEL=<exact-provider-model-id>
PROMPTSEC_GENERATION_BASE_URL=http://127.0.0.1:11434/v1

# Leave unset for an unauthenticated loopback server. If a local server is
# explicitly configured to require a token, set it only in the shell process:
# PROMPTSEC_GENERATION_API_KEY=<local-server-token>
