# Python bytecode and tooling
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.pytest-tmp/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/

# Environments and local configuration
.venv/
venv/
.env
.env.*
!.env.example

# Editors and operating systems
.idea/
.vscode/
.DS_Store
Thumbs.db

# Downloaded/generated datasets and reports
data/*
!data/.gitkeep
!data/README.md
!data/policybench/
data/policybench/*
!data/policybench/policies/
!data/policybench/policies/*.yaml
!data/releases/
data/releases/*
!data/releases/*/
data/releases/*/*

# Publishable release metadata only. JSONL payloads, review queues, and the full
# local checksum manifest remain ignored for every release version.
!data/releases/*/dataset_card.md
!data/releases/*/sources.json
!data/releases/*/licenses.json
!data/releases/*/statistics.json
!data/releases/*/deduplication_report.json
!data/releases/*/split_report.json
!data/releases/*/release_manifest.json
!data/releases/*/checksums_pipeline.txt
data/releases/**/*.jsonl
data/releases/**/checksums.sha256
reports/*
!reports/.gitkeep
!reports/README.md
!reports/data_statistics/
reports/data_statistics/*
!reports/data_statistics/*.json
!reports/data_statistics/*.md
!reports/source_integration/
!reports/source_integration/*.md
!reports/quality_review/
!reports/quality_review/*.json
!reports/quality_review/*.md
reports/quality_review/*.jsonl
!reports/license_review/
!reports/license_review/*.json
!reports/license_review/*.md

# Review queues contain source-derived text and are reconstructed locally.
reports/label_mapping/**

# Local classical-baseline binaries are reproducible and must never be committed.
artifacts/

# Colab/Transformer runtime outputs and caches are always local or Drive-owned.
checkpoints/
training-reports/
drive-sync/
tensorboard/
tb_logs/
.hf-cache/
.huggingface/
**/.cache/huggingface/
**/promptsec_data/
*.safetensors
*.ckpt
*.pt
*.pth

# PolicyBench acquisition artifacts, releases, caches, and review payloads are local.
# Authored policy catalogues above are the only tracked files under data/policybench.
data/generated/
data/review/
