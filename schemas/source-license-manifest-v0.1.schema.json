{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LIGHTER91/PromptSec-FM/schemas/source-license-manifest-v0.1.schema.json",
  "title": "PromptSec Source License Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "verified_at",
    "upstream",
    "license_status",
    "components",
    "constraints",
    "citations"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "0.1" },
    "source_id": { "type": "string", "minLength": 1 },
    "verified_at": { "type": "string", "format": "date" },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["homepage", "repository", "revision"],
      "properties": {
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "revision": { "type": "string", "minLength": 1 }
      }
    },
    "license_status": {
      "enum": ["single", "multiple", "unclear"]
    },
    "acquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "cache_path",
        "license_file",
        "used_files",
        "resolved_revision"
      ],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "cache_path": { "type": "string", "minLength": 1 },
        "license_file": { "type": "string", "minLength": 1 },
        "used_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "resolved_revision": { "type": "string", "minLength": 1 },
        "package_name": { "type": ["string", "null"] },
        "package_version": { "type": ["string", "null"] },
        "benchmark_version": { "type": ["string", "null"] },
        "snapshot_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scope", "license_expression", "license_url", "redistribution", "notes"],
        "properties": {
          "scope": { "type": "string", "minLength": 1 },
          "license_expression": { "type": "string", "minLength": 1 },
          "license_url": { "type": "string", "format": "uri" },
          "redistribution": {
            "enum": ["allowed", "conditional", "not-redistributed", "unknown"]
          },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "citations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
